{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=HapagPortalDb;Trusted_Connection=true;TrustServerCertificate=true;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_USER_SECRETS_OR_ENV_VARIABLE",
    "Issuer": "HapagPortal",
    "Audience": "HapagPortalClients",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "https://portal.hapag-lloyd.cl"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
