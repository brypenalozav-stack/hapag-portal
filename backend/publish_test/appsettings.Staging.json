{
  "ConnectionStrings": {
    "DefaultConnection": "Host=${PGHOST};Port=${PGPORT};Database=${PGDATABASE};Username=${PGUSER};Password=${PGPASSWORD}"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_STAGING_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "HapagPortal",
    "Audience": "HapagPortalClients",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "https://staging.hapag-portal.example.com"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
