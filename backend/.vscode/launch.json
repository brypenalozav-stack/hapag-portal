{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "HapagPortal WebApi (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/HapagPortal.WebApi/bin/Debug/net10.0/HapagPortal.WebApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/HapagPortal.WebApi",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5072"
      },
      "launchBrowser": {
        "enabled": true,
        "args": "http://localhost:5072/swagger",
        "windows": {
          "command": "cmd.exe",
          "args": "/C start http://localhost:5072/swagger"
        }
      }
    },
    {
      "name": "HapagPortal WebApi (HTTPS Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/HapagPortal.WebApi/bin/Debug/net10.0/HapagPortal.WebApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/HapagPortal.WebApi",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7062;http://localhost:5072"
      },
      "launchBrowser": {
        "enabled": true,
        "args": "https://localhost:7062/swagger",
        "windows": {
          "command": "cmd.exe",
          "args": "/C start https://localhost:7062/swagger"
        }
      }
    }
  ]
}
